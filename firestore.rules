rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
//  Türkiye Together — Firestore security rules
//
//  INTERIM hardening (replaces the wide-open "allow read, write: if true").
//  • Requires an authenticated user for any access. The app signs every visitor
//    in anonymously (see sync.js), so there's still no login screen — but random
//    unauthenticated scripts can no longer read, write, or wipe the database.
//  • Forbids "list" so nobody can enumerate everyone else's trips.
//  • Forbids "delete" so a trip can't be destroyed from the browser.
//
//  Sharing model: a trip lives at /trips/{code}. Anyone signed in who knows the
//  (secret) code can collaborate — i.e. "anyone with the link", like a shared
//  Google Doc. Keep invite links private. Newly created trips use a long random
//  code so they can't be guessed.
//
//  NOTE: this is an interim step, not per-user-private storage. True private
//  accounts (each trip visible only to its members) require real sign-in and a
//  members list — that's Phase 1 of the product rebuild.
//
//  To apply: Firebase console → Firestore Database → Rules → paste → Publish.
//  First enable: Firebase console → Authentication → Sign-in method → Anonymous.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    match /trips/{code} {
      allow get, create, update: if request.auth != null;
      allow list, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
